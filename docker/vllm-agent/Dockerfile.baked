# Baked-weights variant of sc-vllm-agent.
#
# Layers the HuggingFace weights for a specific model INTO the image so a
# rented vast.ai host pulls once from GHCR and has everything it needs —
# no runtime HF download, no HF rate-limit risk, ~2-3 min cold boots
# instead of ~10 min.
#
# CRITICAL: weights are split across multiple RUN steps so that Docker
# produces several 2-4 GB layers instead of one giant 10+ GB layer. Docker
# pulls up to 3 layers in parallel, but a SINGLE big layer is one
# sequential TCP stream — GHCR throttles individual streams to
# ~200-500 Mbps, so a single 11 GB layer takes 3-15 min regardless of
# host bandwidth. Splitting lets fast hosts actually pull in parallel.
#
# Build args:
#   BASE_IMAGE   — the sha-tagged sc-vllm-agent base built by build-agent.yml
#   HF_REPO      — e.g., Qwen/Qwen2.5-7B-Instruct
#   HF_REVISION  — commit SHA or tag (defaults to "main")
#
# One image per model; tag pattern is sc-vllm-agent-<slug>:<git-sha>.
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG HF_REPO
ARG HF_REVISION=main
# HF_TOKEN is only needed for gated repos (Llama, etc). Ungated repos like
# Qwen work without it. Pass via --secret in build-push-action for security.
ARG HF_TOKEN=""

# hf_transfer saturates multi-Gbps pipes. The base vllm-openai image already
# has it installed as a dependency of huggingface_hub[hf_transfer].
ENV HF_HUB_ENABLE_HF_TRANSFER=1

RUN test -n "$HF_REPO" || (echo "ERROR: HF_REPO build-arg is required" && exit 1)

# ---- Layer 1: small config/tokenizer files (~30 MB) -----------------------
# These almost never change and are trivial to pull.
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id=os.environ["HF_REPO"],
    revision=os.environ["HF_REVISION"],
    cache_dir="/root/.cache/huggingface/hub",
    token=os.environ.get("HF_TOKEN") or None,
    allow_patterns=[
        "*.json", "*.txt", "*.md", "*.py",
        "tokenizer*", "special_tokens*", "vocab*", "merges*",
        "generation_config*", "chat_template*",
    ],
)
PY

# ---- Layer 2: shards 1-3 --------------------------------------------------
# Downloads in parallel with layer 3 + 4 on the host.
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id=os.environ["HF_REPO"],
    revision=os.environ["HF_REVISION"],
    cache_dir="/root/.cache/huggingface/hub",
    token=os.environ.get("HF_TOKEN") or None,
    allow_patterns=[
        "*-00001-of-*.safetensors",
        "*-00002-of-*.safetensors",
        "*-00003-of-*.safetensors",
    ],
)
PY

# ---- Layer 3: shards 4-6 --------------------------------------------------
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id=os.environ["HF_REPO"],
    revision=os.environ["HF_REVISION"],
    cache_dir="/root/.cache/huggingface/hub",
    token=os.environ.get("HF_TOKEN") or None,
    allow_patterns=[
        "*-00004-of-*.safetensors",
        "*-00005-of-*.safetensors",
        "*-00006-of-*.safetensors",
    ],
)
PY

# ---- Layer 4: shards 7-10 (covers bigger 8B/13B models) -------------------
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id=os.environ["HF_REPO"],
    revision=os.environ["HF_REVISION"],
    cache_dir="/root/.cache/huggingface/hub",
    token=os.environ.get("HF_TOKEN") or None,
    allow_patterns=[
        "*-00007-of-*.safetensors",
        "*-00008-of-*.safetensors",
        "*-00009-of-*.safetensors",
        "*-00010-of-*.safetensors",
    ],
)
PY

# ---- Layer 5: shards 11-20 (for 30B+ quantized models) --------------------
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id=os.environ["HF_REPO"],
    revision=os.environ["HF_REVISION"],
    cache_dir="/root/.cache/huggingface/hub",
    token=os.environ.get("HF_TOKEN") or None,
    allow_patterns=[
        "*-0001[1-9]-of-*.safetensors",
        "*-00020-of-*.safetensors",
    ],
)
PY

# ---- Layer 6: catch-all for any remaining files ---------------------------
# Models that use single-file safetensors, model.bin variants, or unusual
# shard naming conventions get picked up here. Excludes the variants vLLM
# doesn't use (saves ~30-50% on some repos).
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id=os.environ["HF_REPO"],
    revision=os.environ["HF_REVISION"],
    cache_dir="/root/.cache/huggingface/hub",
    token=os.environ.get("HF_TOKEN") or None,
    ignore_patterns=["*.gguf", "*.ot", "*.msgpack", "*.h5", "original/*"],
)
PY

# Tell vLLM + transformers to never hit the HF API at runtime. Without this
# the boot stalls for 5-10 s when the host has firewalled outbound HF traffic.
ENV HF_HUB_OFFLINE=1
ENV TRANSFORMERS_OFFLINE=1

# Stamp the baked-in model identity into the image so `docker inspect` and
# our debug panel can see it without parsing the tag.
ENV SC_BAKED_HF_REPO=${HF_REPO}
ENV SC_BAKED_HF_REVISION=${HF_REVISION}
LABEL sc.baked.hf_repo=${HF_REPO}
LABEL sc.baked.hf_revision=${HF_REVISION}
