# Baked-weights variant of sc-vllm-agent.
#
# Layers the HuggingFace weights for a specific model INTO the image so a
# rented vast.ai host pulls once from GHCR and has everything it needs —
# no runtime HF download, no HF rate-limit risk.
#
# CRITICAL — layer granularity: each individual safetensor shard is its own
# RUN step, producing a separate Docker layer. This matters because:
#   1. Docker pulls up to 3 layers in parallel — but a single large layer
#      is ONE sequential TCP stream that can't be parallelized.
#   2. GHCR's Fastly CDN applies per-stream throttling and connection
#      timeouts. A single >4 GB layer risks getting dropped mid-pull and
#      Docker retries the whole layer, leading to the stuck "0% CPU while
#      loading" pattern we saw on 4 hosts.
# Target: no individual layer > ~4 GB.
#
# Build args:
#   BASE_IMAGE   — the sha-tagged sc-vllm-agent base built by build-agent.yml
#   HF_REPO      — e.g., Qwen/Qwen2.5-7B-Instruct
#   HF_REVISION  — commit SHA or tag (defaults to "main")
#
# One image per model; tag pattern is sc-vllm-agent-<slug>:<git-sha>.
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG HF_REPO
ARG HF_REVISION=main
# HF_TOKEN is only needed for gated repos (Llama, etc). Ungated repos like
# Qwen work without it. Pass via --secret in build-push-action for security.
ARG HF_TOKEN=""

# hf_transfer saturates multi-Gbps pipes during the build. The base
# vllm-openai image already has it installed.
ENV HF_HUB_ENABLE_HF_TRANSFER=1

RUN test -n "$HF_REPO" || (echo "ERROR: HF_REPO build-arg is required" && exit 1)

# ---- Layer 1: config/tokenizer (~30 MB) -----------------------------------
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id=os.environ["HF_REPO"],
    revision=os.environ["HF_REVISION"],
    cache_dir="/root/.cache/huggingface/hub",
    token=os.environ.get("HF_TOKEN") or None,
    allow_patterns=[
        "*.json", "*.txt", "*.md", "*.py",
        "tokenizer*", "special_tokens*", "vocab*", "merges*",
        "generation_config*", "chat_template*",
    ],
)
PY

# ---- One layer per safetensor shard --------------------------------------
# Covers up to 16 shards (enough for most models up to 70B quantized).
# Empty layers are cheap (~100 bytes). huggingface_hub's snapshot_download
# is idempotent — already-cached files are skipped — so iterating through
# all potential shards adds no wasted bandwidth during build.

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00001-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00002-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00003-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00004-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00005-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00006-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00007-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=["*-00008-of-*.safetensors"])
PY

RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  allow_patterns=[f"*-{i:05d}-of-*.safetensors" for i in range(9, 17)])
PY

# ---- Catch-all for any remaining model files -----------------------------
# Picks up non-standard names (pytorch_model.bin, consolidated.safetensors,
# single-file safetensors without shard suffix, etc.) that slipped past the
# per-shard patterns above. Excludes formats vLLM never uses.
RUN HF_REPO="$HF_REPO" HF_REVISION="$HF_REVISION" HF_TOKEN="$HF_TOKEN" \
    python3 - <<'PY'
import os
from huggingface_hub import snapshot_download
snapshot_download(os.environ["HF_REPO"], revision=os.environ["HF_REVISION"],
  cache_dir="/root/.cache/huggingface/hub", token=os.environ.get("HF_TOKEN") or None,
  ignore_patterns=["*.gguf", "*.ot", "*.msgpack", "*.h5", "original/*"])
PY

# Tell vLLM + transformers to never hit the HF API at runtime.
ENV HF_HUB_OFFLINE=1
ENV TRANSFORMERS_OFFLINE=1

# Audit trail inside the image.
ENV SC_BAKED_HF_REPO=${HF_REPO}
ENV SC_BAKED_HF_REVISION=${HF_REVISION}
LABEL sc.baked.hf_repo=${HF_REPO}
LABEL sc.baked.hf_revision=${HF_REVISION}
