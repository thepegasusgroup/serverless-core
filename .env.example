# Supabase (copy from https://supabase.com/dashboard/project/<ref>/settings/api)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# vast.ai (https://cloud.vast.ai/account/)
VAST_API_KEY=

# Shared secret agents use to call /internal/* endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_SHARED_SECRET=

# Public URL of this FastAPI control plane. At M1 this is localhost;
# at M2 it becomes the Fly.io URL so rented vast.ai agents can call back.
PUBLIC_API_URL=http://localhost:8000

# Origins allowed to hit /admin/* from a browser (Next.js dashboard in M4).
CORS_ALLOWED_ORIGINS=http://localhost:3000
